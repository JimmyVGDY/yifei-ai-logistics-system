<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="jimmy.logistics.mapper.LogisticsCrudMapper">

    <!--
        通用 CRUD 需要动态表名和字段名，这里的 ${} 只能接收 Service 层白名单配置生成的值。
        业务参数仍使用 #{} 预编译绑定，避免把前端输入直接拼进 SQL。
    -->
    <insert id="insertRecord">
        insert into ${tableName}
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <foreach collection="fields" item="field">
                ${field.column},
            </foreach>
        </trim>
        values
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <foreach collection="fields" item="field">
                #{field.value},
            </foreach>
        </trim>
    </insert>

    <!-- 更新只写入请求中明确传入且通过白名单过滤的字段，避免未传字段覆盖原值。 -->
    <update id="updateRecord">
        update ${tableName}
        <set>
            <foreach collection="fields" item="field">
                ${field.column} = #{field.value},
            </foreach>
            <if test="increaseVersion">
                version = version + 1,
            </if>
        </set>
        where id = #{id}
    </update>

    <!-- 已迁移 deleted 字段的表走逻辑删除，同时可更新审计字段和版本号。 -->
    <update id="logicalDelete">
        update ${tableName}
        <set>
            deleted = 1,
            <foreach collection="fields" item="field">
                ${field.column} = #{field.value},
            </foreach>
            <if test="increaseVersion">
                version = version + 1,
            </if>
        </set>
        where id = #{id}
          and deleted = 0
    </update>

    <!-- 兼容未执行增量迁移的旧表：没有 deleted 字段时才回退物理删除。 -->
    <delete id="physicalDelete">
        delete from ${tableName}
        where id = #{id}
    </delete>

    <!-- 生成客户、司机、用户、角色等业务编号前先查重，降低随机编号冲突风险。 -->
    <select id="countByBusinessCode" resultType="int">
        select count(1)
        from ${tableName}
        where ${columnName} = #{code}
    </select>

    <!-- 新增客户账号时，优先从历史运单中找到同名客户绑定，避免客户档案和账号重复割裂。 -->
    <select id="selectCustomerIdFromOrdersByName" resultType="long">
        select customer_id
        from logistics_order
        where customer_name = #{customerName}
          and customer_id is not null
        order by created_at desc
        limit 1
    </select>

    <!-- 如果历史运单没有可用 customer_id，则回退到客户档案表按名称匹配。 -->
    <select id="selectCustomerIdByName" resultType="long">
        select id
        from logistics_customer
        where customer_name = #{customerName}
        order by id
        limit 1
    </select>

    <!-- 手输客户名称且系统无档案时，创建一条最小客户档案，后续可在客户管理中补全联系人和地址。 -->
    <insert id="insertCustomerForAccount">
        insert into logistics_customer
            (id, customer_code, customer_name, contact_name, contact_phone, province, city, address, status, created_at, updated_at)
        values
            (#{id}, #{customerCode}, #{customerName}, #{customerName}, '', '待补充', '待补充', '待补充', 'ACTIVE', #{now}, #{now})
    </insert>

    <!-- 判断当前选择的角色是否为客户角色，只有客户角色才需要绑定客户数据权限。 -->
    <select id="selectRoleCodeById" resultType="string">
        select role_code
        from sys_role
        where id = #{roleId}
        limit 1
    </select>

    <!-- 同一客户下第一个客户账号标记为主账号，后续账号标记为子账号。 -->
    <select id="countCustomerAccounts" resultType="int">
        select count(1)
        from sys_user u
        join sys_role r on r.id = u.role_id
        where u.customer_id = #{customerId}
          and r.role_code = 'CUSTOMER'
          <if test="excludeUserId != null">
              and u.id != #{excludeUserId}
          </if>
    </select>
</mapper>
