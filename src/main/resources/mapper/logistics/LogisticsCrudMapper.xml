<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="jimmy.logistics.mapper.LogisticsCrudMapper">

    <insert id="insertRecord">
        insert into ${tableName}
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <foreach collection="fields" item="field">
                ${field.column},
            </foreach>
        </trim>
        values
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <foreach collection="fields" item="field">
                #{field.value},
            </foreach>
        </trim>
    </insert>

    <update id="updateRecord">
        update ${tableName}
        <set>
            <foreach collection="fields" item="field">
                ${field.column} = #{field.value},
            </foreach>
            <if test="increaseVersion">
                version = version + 1,
            </if>
        </set>
        where id = #{id}
    </update>

    <update id="logicalDelete">
        update ${tableName}
        <set>
            deleted = 1,
            <foreach collection="fields" item="field">
                ${field.column} = #{field.value},
            </foreach>
            <if test="increaseVersion">
                version = version + 1,
            </if>
        </set>
        where id = #{id}
          and deleted = 0
    </update>

    <delete id="physicalDelete">
        delete from ${tableName}
        where id = #{id}
    </delete>

    <select id="countByBusinessCode" resultType="int">
        select count(1)
        from ${tableName}
        where ${columnName} = #{code}
    </select>
</mapper>
