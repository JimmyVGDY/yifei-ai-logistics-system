<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="jimmy.ai.mapper.AiPromptTemplateMapper">

    <resultMap id="AiPromptTemplateResultMap" type="jimmy.ai.entity.AiPromptTemplate">
        <id property="id" column="id"/>
        <result property="templateCode" column="template_code"/>
        <result property="templateName" column="template_name"/>
        <result property="templateVersion" column="template_version"/>
        <result property="templateType" column="template_type"/>
        <result property="templateContent" column="template_content"/>
        <result property="requiredVariables" column="required_variables"/>
        <result property="optionalVariables" column="optional_variables"/>
        <result property="outputSchema" column="output_schema"/>
        <result property="modelPurpose" column="model_purpose"/>
        <result property="status" column="status"/>
        <result property="remark" column="remark"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
        <result property="deleted" column="deleted"/>
    </resultMap>

    <select id="findLatestActive" resultMap="AiPromptTemplateResultMap">
        select id, template_code, template_name, template_version, template_type, template_content,
               required_variables, optional_variables, output_schema, model_purpose, status, remark,
               created_at, updated_at, deleted
        from ai_prompt_template
        where template_code = #{templateCode}
          and status = 'ACTIVE'
          and deleted = 0
        order by template_version desc, updated_at desc
        limit 1
    </select>

</mapper>
