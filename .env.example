# ==========================================
# 物流管理平台 Docker 部署环境变量
# ==========================================
# 使用方式:
#   cp .env.example .env
#   编辑 .env 修改实际值
#   docker compose up -d
# ==========================================

# ---- 数据库 ----
MYSQL_ROOT_PASSWORD=***

# ---- Redis ----
# 留空 = 无密码
REDIS_PASSWORD=

# ---- RabbitMQ ----
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest

# ---- 端口（如宿主机端口冲突可修改） ----
MYSQL_PORT=3306
REDIS_PORT=6379
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672
ES_PORT=9200
NACOS_PORT=8848
SENTINEL_PORT=8858
APP_PORT=8080
