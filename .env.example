# ==========================================
# 物流管理平台 Docker 部署环境变量
# ==========================================
# 使用方式:
#   cp .env.example .env
#   编辑 .env 修改实际值
#   docker compose up -d
# ==========================================

# Production checklist:
# - Change MYSQL_ROOT_PASSWORD, REDIS_PASSWORD, RabbitMQ credentials, GRAFANA_PASSWORD.
# - Set XXL_JOB_ACCESS_TOKEN, APP_ENCRYPT_KEY, and AI_INTERNAL_SHARED_SECRET.
# - Infrastructure ports bind to 127.0.0.1 by default. Set *_BIND explicitly before exposing them.

# ---- 数据库 ----
MYSQL_ROOT_PASSWORD=***

# ---- Redis ----
# 留空 = 无密码
REDIS_PASSWORD=

# ---- RabbitMQ ----
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest

# ---- 监控与调度 ----
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin
XXL_JOB_PORT=8081
XXL_JOB_ACCESS_TOKEN=

# ---- AI internal API ----
AI_INTERNAL_SHARED_SECRET=

# ---- AES 加密密钥（启用加密时必配，长度必须为 16/24/32 UTF-8 字节） ----
APP_ENCRYPT_KEY=

# ---- ID / 登录安全 ----
APP_ID_WORKER_ID=0
APP_AUTH_LOGIN_MAX_FAILURES=5
APP_AUTH_LOGIN_LOCK_MINUTES=15
APP_AUTH_LOGIN_RATE_LIMIT_PER_MINUTE=10
APP_AI_SSE_IDLE_TIMEOUT_MS=30000

# ---- 端口（如宿主机端口冲突可修改） ----
MYSQL_BIND=127.0.0.1
MYSQL_PORT=3306
REDIS_BIND=127.0.0.1
REDIS_PORT=6379
RABBITMQ_BIND=127.0.0.1
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672
ES_BIND=127.0.0.1
ES_PORT=9200
NACOS_BIND=127.0.0.1
NACOS_PORT=8848
SENTINEL_BIND=127.0.0.1
SENTINEL_PORT=8858
XXL_JOB_BIND=127.0.0.1
APP_PORT=8080
PROMETHEUS_BIND=127.0.0.1
PROMETHEUS_PORT=9090
GRAFANA_BIND=127.0.0.1
GRAFANA_PORT=3000
KIBANA_BIND=127.0.0.1
KIBANA_PORT=5601
AI_SERVICE_BIND=127.0.0.1
AI_SERVICE_PORT=8001
QDRANT_BIND=127.0.0.1
QDRANT_PORT=6333
