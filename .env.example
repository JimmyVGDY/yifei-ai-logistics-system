# ==========================================
# 物流管理平台 Docker 部署环境变量
# ==========================================
# 使用方式:
#   cp .env.example .env
#   编辑 .env 修改实际值
#   docker compose up -d
# ==========================================

# ---- 数据库 ----
MYSQL_ROOT_PASSWORD=***

# ---- Redis ----
# 留空 = 无密码
REDIS_PASSWORD=

# ---- RabbitMQ ----
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest

# ---- 监控与调度 ----
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin
XXL_JOB_PORT=8081
XXL_JOB_ACCESS_TOKEN=

# ---- AES 加密密钥（生产环境必配，至少 16 字符，开发环境留空 = 明文存储） ----
APP_ENCRYPT_KEY=

# ---- 端口（如宿主机端口冲突可修改） ----
MYSQL_PORT=3306
REDIS_PORT=6379
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672
ES_PORT=9200
NACOS_PORT=8848
SENTINEL_PORT=8858
APP_PORT=8080
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
KIBANA_PORT=5601
